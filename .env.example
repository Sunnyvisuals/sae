# Supabase — constellation collective (Acte III, partagée entre tous les visiteurs)
# 1. Créer un projet sur supabase.com
# 2. Exécuter supabase/constellation_stars.sql dans le SQL Editor
# 3. Renseigner les clés ci-dessous

# Dev local (Vite) — client direct
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Vercel (prod) — route /api/constellation (recommandé, sans exposer la clé au bundle)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Reset BDD comètes (panneau dev « Reset BDD comètes ») — jamais dans le bundle client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optionnel : autoriser DELETE en prod (déconseillé). Sinon : dev + preview Vercel uniquement.
# ALLOW_DEV_CONSTELLATION_RESET=true

# Sans config : en dev, étoiles démo locales ; en prod, ciel vide jusqu’à configuration.
