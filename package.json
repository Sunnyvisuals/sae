{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "start": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "assets:lang-bridge-mp4": "ffmpeg -y -i public/transitions/trans2-alpha.webm -an -c:v libx264 -pix_fmt yuv420p -profile:v high -movflags +faststart public/transitions/trans2-alpha.mp4",
    "assets:act12-bridge-mp4": "ffmpeg -y -i public/transitions/trans2-alpha-act12.webm -an -c:v libx264 -pix_fmt yuv420p -profile:v high -movflags +faststart public/transitions/trans2-alpha-act12.mp4",
    "preview": "vite preview --port 3000 --host",
    "deploy:netlify": "npm run build && npx netlify deploy --prod --dir=dist",
    "deploy:vercel": "vercel deploy --prod",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "knip": "knip",
    "verify": "npm run lint && npm run build",
    "assets:favicons": "node scripts/generate-favicons.mjs"
  },
  "dependencies": {
    "gsap": "^3.14.2",
    "howler": "^2.2.4",
    "lenis": "^1.3.21",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@turf/turf": "^7.3.4",
    "@types/howler": "^2.2.12",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "knip": "^5.88.1",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
